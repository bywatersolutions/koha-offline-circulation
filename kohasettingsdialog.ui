<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>KohaSettingsDialog</class>
 <widget class="QDialog" name="KohaSettingsDialog">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>540</width>
    <height>520</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>Koha Connection Settings - Koha Offline Circulation</string>
  </property>
  <property name="modal">
   <bool>true</bool>
  </property>
  <layout class="QVBoxLayout" name="verticalLayout">
   <item>
    <widget class="QGroupBox" name="groupBoxServer">
     <property name="title">
      <string>Koha Server</string>
     </property>
     <layout class="QFormLayout" name="formLayoutServer">
      <item row="0" column="0">
       <widget class="QLabel" name="labelBaseUrl">
        <property name="text">
         <string>Staff interface URL</string>
        </property>
       </widget>
      </item>
      <item row="0" column="1">
       <widget class="QLineEdit" name="lineEditBaseUrl">
        <property name="placeholderText">
         <string>https://koha-staff.example.org</string>
        </property>
       </widget>
      </item>
      <item row="1" column="0">
       <widget class="QLabel" name="labelUserid">
        <property name="text">
         <string>Username</string>
        </property>
       </widget>
      </item>
      <item row="1" column="1">
       <widget class="QLineEdit" name="lineEditUserid"/>
      </item>
      <item row="2" column="0">
       <widget class="QLabel" name="labelPassword">
        <property name="text">
         <string>Password</string>
        </property>
       </widget>
      </item>
      <item row="2" column="1">
       <widget class="QLineEdit" name="lineEditPassword">
        <property name="echoMode">
         <enum>QLineEdit::Password</enum>
        </property>
       </widget>
      </item>
      <item row="3" column="1">
       <widget class="QLabel" name="labelPasswordNote">
        <property name="text">
         <string>The password is stored on this computer. Use a dedicated Koha account with minimal permissions.</string>
        </property>
        <property name="wordWrap">
         <bool>true</bool>
        </property>
       </widget>
      </item>
     </layout>
    </widget>
   </item>
   <item>
    <widget class="QGroupBox" name="groupBoxMethod">
     <property name="title">
      <string>Download Method</string>
     </property>
     <layout class="QVBoxLayout" name="verticalLayoutMethod">
      <item>
       <widget class="QRadioButton" name="radioButtonReports">
        <property name="text">
         <string>Saved reports (fastest, needs the report IDs below)</string>
        </property>
        <property name="checked">
         <bool>true</bool>
        </property>
       </widget>
      </item>
      <item>
       <layout class="QFormLayout" name="formLayoutReports">
        <item row="0" column="0">
         <widget class="QLabel" name="labelBorrowersReport">
          <property name="text">
           <string>Borrowers report ID</string>
          </property>
         </widget>
        </item>
        <item row="0" column="1">
         <widget class="QSpinBox" name="spinBoxBorrowersReport">
          <property name="maximum">
           <number>999999</number>
          </property>
         </widget>
        </item>
        <item row="1" column="0">
         <widget class="QLabel" name="labelIssuesReport">
          <property name="text">
           <string>Issues report ID</string>
          </property>
         </widget>
        </item>
        <item row="1" column="1">
         <widget class="QSpinBox" name="spinBoxIssuesReport">
          <property name="maximum">
           <number>999999</number>
          </property>
         </widget>
        </item>
       </layout>
      </item>
      <item>
       <widget class="QRadioButton" name="radioButtonRest">
        <property name="text">
         <string>REST API (no reports needed, requires RESTBasicAuth)</string>
        </property>
       </widget>
      </item>
     </layout>
    </widget>
   </item>
   <item>
    <widget class="QGroupBox" name="groupBoxUpload">
     <property name="title">
      <string>Upload</string>
     </property>
     <layout class="QFormLayout" name="formLayoutUpload">
      <item row="0" column="0">
       <widget class="QLabel" name="labelBranchcode">
        <property name="text">
         <string>Branch code</string>
        </property>
       </widget>
      </item>
      <item row="0" column="1">
       <widget class="QLineEdit" name="lineEditBranchcode">
        <property name="placeholderText">
         <string>The branch transactions are recorded under, e.g. CPL</string>
        </property>
       </widget>
      </item>
      <item row="1" column="1">
       <widget class="QCheckBox" name="checkBoxUploadPending">
        <property name="text">
         <string>Queue uploads for staff review instead of processing immediately</string>
        </property>
       </widget>
      </item>
     </layout>
    </widget>
   </item>
   <item>
    <widget class="QGroupBox" name="groupBoxAutomatic">
     <property name="title">
      <string>Automatic Downloads</string>
     </property>
     <layout class="QVBoxLayout" name="verticalLayoutAutomatic">
      <item>
       <layout class="QHBoxLayout" name="horizontalLayoutNightly">
        <item>
         <widget class="QCheckBox" name="checkBoxNightly">
          <property name="text">
           <string>Download nightly at</string>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QTimeEdit" name="timeEditNightly">
          <property name="displayFormat">
           <string>HH:mm</string>
          </property>
         </widget>
        </item>
        <item>
         <spacer name="horizontalSpacerNightly">
          <property name="orientation">
           <enum>Qt::Horizontal</enum>
          </property>
          <property name="sizeHint" stdset="0">
           <size>
            <width>40</width>
            <height>20</height>
           </size>
          </property>
         </spacer>
        </item>
       </layout>
      </item>
      <item>
       <widget class="QCheckBox" name="checkBoxOnLaunch">
        <property name="text">
         <string>Download at startup if the database is older than 24 hours</string>
        </property>
       </widget>
      </item>
     </layout>
    </widget>
   </item>
   <item>
    <widget class="QDialogButtonBox" name="buttonBox">
     <property name="orientation">
      <enum>Qt::Horizontal</enum>
     </property>
     <property name="standardButtons">
      <set>QDialogButtonBox::Cancel|QDialogButtonBox::Save</set>
     </property>
    </widget>
   </item>
  </layout>
 </widget>
